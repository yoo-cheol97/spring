<!DOCTYPE mapper
    PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
    "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.ktdsuniversity.edu.board.dao.BoardDao">

    <select id="selectBoardCount" resultType="_int">
        SELECT COUNT(ID)
          FROM BOARD
    </select>
    
	<select id="selectBoardList" resultType="com.ktdsuniversity.edu.board.vo.BoardVO">
        SELECT ID
             , SUBJECT
             , CONTENT
             , EMAIL
             , VIEW_CNT
             , TO_CHAR(CRT_DT, 'YYYY-MM-DD HH24:MI:SS') AS CRT_DT
             , TO_CHAR(MDFY_DT, 'YYYY-MM-DD HH24:MI:SS') AS MDFY_DT
             , FILE_NAME
             , ORIGIN_FILE_NAME
          FROM BOARD
	</select>

</mapper>