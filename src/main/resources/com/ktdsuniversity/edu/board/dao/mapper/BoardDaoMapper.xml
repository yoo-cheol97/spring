<!DOCTYPE mapper
    PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
    "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.ktdsuniversity.edu.board.dao.BoardDao">

    <select id="selectBoardCount"
            parameterType="com.ktdsuniversity.edu.board.vo.request.SearchListVO" 
            resultType="_int">
        SELECT COUNT(B.ID)
          FROM BOARD B
         INNER JOIN MEMBERS M
            ON B.EMAIL = M.EMAIL
           <if test='searchKeyword != null and searchKeyword != ""'>
            <if test='searchType == "email"'>
         WHERE M.EMAIL LIKE '%' || #{searchKeyword}|| '%'
            </if>
             <if test='searchType == "name"'>
         WHERE M.NAME LIKE '%' || #{searchKeyword}|| '%'
           </if>
            <if test='searchType == "subject"'>
         WHERE B.SUBJECT LIKE '%' || #{searchKeyword}|| '%'
           </if>
            <if test='searchType == "content"'>
         WHERE B.CONTENT LIKE '%' || #{searchKeyword}|| '%'
           </if>
            <if test='searchType == "subject content"'>
         WHERE B.SUBJECT LIKE '%' || #{searchKeyword}|| '%'
            OR B.CONTENT LIKE '%' || #{searchKeyword}|| '%'
            </if>
           </if>
    </select>
    
	<select id="selectBoardList" 
	        parameterType="com.ktdsuniversity.edu.board.vo.request.SearchListVO"
	        resultMap="BoardVOMap">
	        
	    
	    SELECT *
          FROM (SELECT S.*
                     , ROWNUM AS RNUM
                  FROM ( SELECT B.ID
			                  , B.SUBJECT
			                  , B.CONTENT
			                  , B.EMAIL
			                  , B.VIEW_CNT
			                  , TO_CHAR(B.CRT_DT, 'YYYY-MM-DD HH24:MI:SS') AS CRT_DT
			                  , TO_CHAR(B.MDFY_DT, 'YYYY-MM-DD HH24:MI:SS') AS MDFY_DT
			                  , B.FILE_NAME
			                  , B.ORIGIN_FILE_NAME
			                  , M.NAME
			                  , M.REGIST_DATE
			               FROM BOARD B
                          INNER JOIN MEMBERS M
                             ON B.EMAIL = M.EMAIL
                             <if test='searchKeyword != null and searchKeyword != ""'>
                             <if test='searchType == "email"'>
				          WHERE M.EMAIL LIKE '%' || #{searchKeyword}|| '%'
				             </if>
				              <if test='searchType == "name"'>
				          WHERE M.NAME LIKE '%' || #{searchKeyword}|| '%'
				            </if>
				             <if test='searchType == "subject"'>
				          WHERE B.SUBJECT LIKE '%' || #{searchKeyword}|| '%'
				            </if>
				             <if test='searchType == "content"'>
				          WHERE B.CONTENT LIKE '%' || #{searchKeyword}|| '%'
				            </if>
				             <if test='searchType == "subject content"'>
				          WHERE B.SUBJECT LIKE '%' || #{searchKeyword}|| '%'
				             OR B.CONTENT LIKE '%' || #{searchKeyword}|| '%'
				             </if>
				             </if>
                          ORDER BY B.ID DESC) S
                 WHERE ROWNUM <![CDATA[ <= ]]> (#{pageNo} + 1) * #{listSize})
         WHERE RNUM >= #{pageNo} * #{listSize} + 1    
		      
	</select>
	
	<insert id="insertNewBoard" 
	        parameterType="com.ktdsuniversity.edu.board.vo.request.WriteVO">
	<!-- мғҲлЎӯкІҢ л§Ңл“Өм–ҙм§ҖлҠ” кІҢмӢңкёҖмқҳ PKлҘј лҜёлҰ¬ мғқм„ұн•ҙм„ң WriteVOмқҳ idлқјлҠ” ліҖмҲҳм—җ н• лӢ№н•ңлӢӨ -->
	<selectKey order="BEFORE" 
	           resultType="string"
	           keyProperty="id"> <!-- insertмқҙм „м—җ мҲҳн–үн•ҙлқј, writevoм—җлҠ” мғҲлЎңмҡҙ м•„мқҙл”” -->
	   SELECT 'BO-' || TO_CHAR(SYSDATE, 'YYYYMMDD-') || LPAD(SEQ_BOARD_PK.NEXTVAL, 6, '0')
	     FROM DUAL
	</selectKey>
	INSERT INTO BOARD
	        (ID
             , SUBJECT
             , CONTENT
             , EMAIL
             , VIEW_CNT
             , CRT_DT
             , MDFY_DT
             , FILE_NAME
             , ORIGIN_FILE_NAME
             , FILE_GROUP_ID)
             VALUES
              (#{id}
             , #{subject}
             , #{content}
             , #{email}
             , 0
             , SYSDATE
             , SYSDATE
             , NULL
             , NULL
             , #{fileGroupId}
            )
             
	</insert>
	
	<!-- JOINмқ„ мӮ¬мҡ©н•ҳлҠ” мҝјлҰ¬мқҳ кІ°кіјлҘј
	   Has AлҘј мӮ¬мҡ©н•ҳлҠ” VOм—җкІҢ к°’мқ„ н• лӢ№н•ҳкё° мң„н•ң нғңк·ё -->

    <resultMap type="com.ktdsuniversity.edu.board.vo.BoardVO" 
               id="BoardVOMap"
               autoMapping="true">
     <!-- мҝјлҰ¬м—җ мӮ¬мҡ©лҗҳлҠ” н…Ңмқҙлё”мқҳ PKк°’мқ„ ліҖмҲҳм—җ м ҖмһҘн•  л•Ң мӮ¬мҡ© -->
    <id column="ID" property="id"/>
     <!-- мҝјлҰ¬м—җ мӮ¬мҡ©лҗҳлҠ” н…Ңмқҙлё”мқҳ мқјл°ҳ м»¬лҹјмқҳ к°’мқ„ ліҖмҲҳм—җ м ҖмһҘн•  л•Ң мӮ¬мҡ© -->    
          <!--  
          <result column="SUBJECT" property ="subject"/>
          <result column="CONTENT" property ="content"/>
          <result column="EMAIL" property ="email"/>
          <result column="VIEW_CNT" property ="viewCnt"/>
          <result column="CRT_DT" property ="crtDt"/>
          <result column="MDFY_DT" property ="mdfyDt"/>
          <result column="FILE_NAME" property ="fileName"/>
          <result column="ORIGIN_FILE_NAME" property ="originFileName"/>-->
      <!-- лӢЁмқј VOм—җкІҢ к°’мқ„ н• лӢ№н•ҳлҠ” л°©лІ• 
           н•ҳлӮҳмқҳ ResultMapм—җм„ң collectionкіј associationмқҙ лҸҷмӢңм—җ мӮ¬мҡ©лҗ  л•Ң
           colledctionмқҙ к°ҖмһҘ л§Ҳм§Җл§үм—җ мң„м№ҳн•ҙм•јн•ңлӢӨ
       -->
      <association property="membersVO"
                   javaType="com.ktdsuniversity.edu.members.vo.MembersVO"
                   autoMapping="true">
               <id column="EMAIL" property="email" />
      </association>
   
      <!-- BoardVOм—җ мһҲлҠ” listлҠ” <collection> нғңк·ё мқҙмҡ© -->
    <collection property="files"
                javaType="list"
                ofType="com.ktdsuniversity.edu.files.vo.FilesVO"
                autoMapping="true"> <!-- java.util.list -->
                <id column="FILE_NUM" property="fileNum"/>
                <id column="FILE_GROUP_ID" property="fileGroupId"/>
                <!-- <result column="OBFUSCATE_NAME" property ="obfuscateName"/>
                <result column="DISPLAY_NAME" property ="displayName"/>
                <result column="EXTEND_NAME" property ="extendName"/>
                <result column="FILE_LENGTH" property ="fileLength"/>
                <result column="FILE_PATH" property ="filePath"/> -->
    </collection>
 </resultMap>
	<select id="selectBoardById"
            resultMap="BoardVOMap"
		    parameterType="string">
		  SELECT B.ID
               , B.SUBJECT
               , B.CONTENT
               , B.EMAIL
               , B.VIEW_CNT
               , TO_CHAR(B.CRT_DT, 'YYYY-MM-DD HH24:MI:SS') AS CRT_DT
               , TO_CHAR(B.MDFY_DT, 'YYYY-MM-DD HH24:MI:SS') AS MDFY_DT
               , B.FILE_NAME
               , B.ORIGIN_FILE_NAME
               , F.FILE_NUM
               , F.FILE_GROUP_ID
               , F.OBFUSCATE_NAME
               , F.DISPLAY_NAME
               , F.EXTEND_NAME
               , F.FILE_LENGTH
               , F.FILE_PATH
               , M.NAME
               , TO_CHAR(M.REGIST_DATE, 'YYYY-MM-DD HH24:MI:SS') AS REGIST_DATE
            FROM BOARD B
           INNER JOIN MEMBERS M
              ON B.EMAIL=M.EMAIL
            LEFT OUTER JOIN (SELECT F.FILE_NUM
                                  , FG.FILE_GROUP_ID
                                  , F.OBFUSCATE_NAME
                                  , F.DISPLAY_NAME
                                  , F.EXTEND_NAME
                                  , F.FILE_LENGTH
                                  , F.FILE_PATH
                               FROM FILES_GROUP FG
                              INNER JOIN FILES F
                                 ON FG.FILE_GROUP_ID = F.FILE_GROUP_ID ) F
              ON B.FILE_GROUP_ID = F.FILE_GROUP_ID
           WHERE ID = #{_parameter}
		    </select>

	<update id="updateViewCntIncreaseById"
	        parameterType="string">
	   UPDATE BOARD
   SET VIEW_CNT = VIEW_CNT + 1
 WHERE ID = #{_parameter}
	</update>
	
	<delete id="deleteBoardByArticleId"
	        parameterType="string">
        DELETE
          FROM BOARD
         WHERE ID = #{_parameter}
	</delete>
	<update id="updateboardById" 
	        parameterType="com.ktdsuniversity.edu.board.vo.request.UpdateVO">
	UPDATE BOARD
       SET SUBJECT=#{subject}
         , CONTENT=#{content}
         , MDFY_DT= SYSDATE
         , FILE_GROUP_ID=#{fileGroupId}
     WHERE ID=#{id}
	</update>
	
	<select id="selectFileInBoard"
            resultType="string">
        SELECT F.FILE_PATH 
          FROM BOARD B
         INNER JOIN FILES F
            ON B.FILE_GROUP_ID = F.FILE_GROUP_ID
    </select>
    
    <delete id="deleteAllBoard">
        DELETE
          FROM BOARD
    </delete>
   
    
</mapper>